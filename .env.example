# =============================================================================
# METADATA EXTRACTOR — Environment (.env)
# Backend (Node) + Python-core eyni faylı / Render Environment oxuyur.
# .env faylını git-ə commit ETMƏ — yalnız bu şablon (.env.example) commit olunsun.
# =============================================================================

# --- CORS (Vercel frontend URL-ləri, vergüllə) ---
# CORS_ORIGINS=https://smartmetadata.vercel.app,https://metadata-extractor-kappa.vercel.app

# --- SERVER / RENDER (Backend — server.js) ---
# Render PORT avtomatik verir; lokalda boş buraxa bilərsən (default 3001)
# PORT=3001
NODE_ENV=production
PYTHON_BIN=python3
PYTHONIOENCODING=utf-8
ADMIN_PASSWORD=your_admin_password

# --- İCTİMAİ BACKEND URL (Backend + Python) ---
# Render: https://SIZIN-SERVICE.onrender.com
# Lokal+ngrok: https://xxxx.ngrok-free.dev
# TinEye, tərs şəkil axtarışı, SerpAPI üçün mütləqdir
PUBLIC_APP_URL=
PUBLIC_IMAGE_BASE_URL=

# --- TƏRS ŞƏKİL / VEB AXTARIŞ API (Python) ---
# TinEye — https://tineye.com/api
TINEYE_API_KEY=

# Google Cloud Vision — Web Detection
GOOGLE_VISION_API_KEY=
# GOOGLE_CLOUD_VISION_API_KEY=   # alternativ ad (eyni məqsəd)

# SerpAPI — Google Lens / Reverse Image — https://serpapi.com
SERPAPI_KEY=

# Azure Bing Visual Search
BING_VISUAL_SEARCH_KEY=
# AZURE_BING_VISUAL_SEARCH_KEY=  # alternativ ad

# Brave Search — pulsuz ~2000 sorğu/ay — https://brave.com/search/api
BRAVE_API_KEY=

# Yayılma analizində Google Vision aktivləşdir (1 / 0)
USE_GOOGLE_VISION=0

# --- SOSİAL MEDIA (Python — yt-dlp / instaloader) ---
# RapidAPI (əgər Instagram scraper inteqrasiyası varsa)
RAPIDAPI_KEY=

# Netscape format cookie faylları (tam fayl yolu)
YTDLP_COOKIES_INSTAGRAM=
YTDLP_COOKIES_TWITTER=
YTDLP_COOKIES_FACEBOOK=
YTDLP_COOKIES=

# Instaloader sessiya faylı
# Windows: C:\Users\ADINIZ\AppData\Local\Instaloader\session-ISTIFADECI
INSTAGRAM_SESSION_FILE=
# INSTALOADER_SESSION=            # alternativ ad

# --- YOLO OBYEKT DETEKSİYA (Python — opsional tuning) ---
YOLO_MODEL=yolov8m.pt
YOLO_WORLD_MODEL=yolov8m-worldv2.pt
YOLO_WORLD=1
YOLO_TILED=1
YOLO_MULTISCALE=1
YOLO_SCENE_ONLY=1

# =============================================================================
# FRONTEND (Vercel) — ayrıca Environment Variables bölməsində:
# VITE_API_URL=https://SIZIN-BACKEND.onrender.com
# =============================================================================
