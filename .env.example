# RapidAPI Instagram Scraper Ayarları

# https://rapidapi.com adresinden bir hesap açın ve Instagram Scraper API'sine abone olun

RAPIDAPI_KEY=your_api_key_here



# Sosial media metadata — opsional cookie/sessiya (ictimai postlar üçün lazım deyil)

# Netscape formatında cookie faylları (yt-dlp --cookies)

YTDLP_COOKIES_INSTAGRAM=path/to/instagram_cookies.txt

YTDLP_COOKIES_TWITTER=path/to/twitter_cookies.txt

YTDLP_COOKIES_FACEBOOK=path/to/facebook_cookies.txt

YTDLP_COOKIES=path/to/generic_cookies.txt



# instaloader sessiya faylı (Instagram post metadata üçün)
# Windows: C:\Users\ADINIZ\AppData\Local\Instaloader\session-ISTIFADECI
INSTAGRAM_SESSION_FILE=path/to/session-yourusername

# Tərs şəkil axtarışı (opsional API açarları)
# TinEye: https://tineye.com/api — fayl yükləmə dəstəklənir
TINEYE_API_KEY=

# Google Cloud Vision — Web Detection
GOOGLE_VISION_API_KEY=

# SerpAPI — Google Reverse Image / Lens (PUBLIC_APP_URL lazım)
SERPAPI_KEY=

# Azure Bing Visual Search
BING_VISUAL_SEARCH_KEY=

# Admin giriş parolu (frontend + API qorunması)
ADMIN_PASSWORD=your_admin_password

# Xarici servislərin şəkil URL-ini görməsi üçün (ngrok, prod domen)
# Məs: https://abc123.ngrok-free.app və ya https://api.sizindomen.com
PUBLIC_APP_URL=

